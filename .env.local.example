# Copy to `.env.local` if you prefer file-based local secrets.
# The repo ignores `.env.local`.
#
# Default one-click flow in this repo expects:
# - OPENAI_API_KEY
#
# Optional:
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# - AWS_REGION_NAME
# - S2_API_KEY
# - GEMINI_API_KEY
# - OPENROUTER_API_KEY
# - HUGGINGFACE_API_KEY
# - OLLAMA_API_KEY
# - HF_TOKEN / HUGGINGFACE_HUB_TOKEN
# - GITHUB_USER / GITHUB_TOKEN for autosave pushes on rented servers
# - AI_SCIENTIST_GIT_USER_NAME / AI_SCIENTIST_GIT_USER_EMAIL for commit identity

OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
S2_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_KEY=
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
GITHUB_USER=
GITHUB_TOKEN=
AI_SCIENTIST_GIT_USER_NAME=
AI_SCIENTIST_GIT_USER_EMAIL=
GPU_WATCHDOG_INTERVAL_SEC=600
GPU_IDLE_UTIL_THRESHOLD=5
GPU_IDLE_MEM_THRESHOLD_MB=1024
GPU_ALERT_COOLDOWN_SEC=3600
GPU_WATCHDOG_STARTUP_GRACE_SEC=900
MAX_REPORT_FILE_MB=20
