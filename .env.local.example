# Copy to `.env.local` if you prefer file-based local secrets.
# The repo ignores `.env.local`.
#
# Default one-click flow in this repo expects:
# - OPENAI_API_KEY
#
# Optional:
# - AWS_ACCESS_KEY_ID
# - AWS_SECRET_ACCESS_KEY
# - AWS_REGION_NAME
# - S2_API_KEY
# - GEMINI_API_KEY
# - OPENROUTER_API_KEY
# - HUGGINGFACE_API_KEY
# - OLLAMA_API_KEY
# - HF_TOKEN / HUGGINGFACE_HUB_TOKEN

OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=
S2_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_API_KEY=
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
